aegis-forks/

# Build logs
devnet/*.log

# Devnet generated state
devnet/deploy.env
tmpdir/

# Local diagnostic scripts (leading-underscore = scratch, not for upstream)
devnet/scripts/_*
# Local diagnostic helpers at repo root (leading-dot = hidden / scratch)
/.diag-*.sh
/.check-and-deploy.sh
/.fresh-devnet.sh
/.run-precompile-build.sh
/.wait-rpc.sh

# wasmvm-fork patch backups + rebase scratch
wasmvm-fork/patches/*.bak
wasmvm-fork/patches/*.err

# Downloaded toolchains (don't commit large binaries)
go*.tar.gz

# Dependencies
node_modules/

# Environment / secrets
.env
deployed.json
parliament-state.json
tools/heartbeat-digest/state/

# Bud-seal keys and secrets — NEVER commit
*.key
*.pub
*.sealed
*-secrets.toml
!secrets-template.toml

# Pre-publication security artefacts — local-only until formal disclosure
