+// ── BN254 (alt_bn128) host-function status codes ──────────────────────────
+//
+// Returned in the u32 of `do_bn254_*`'s `VmResult<u32>`. 0 always means
+// "operation completed successfully" for ECADD/ECMUL (output written to
+// the guest-supplied out_ptr). For pairing, 0 = pairings equal, 1 = not
+// equal. Other codes encode `Bn254Error` variants and correspond to a
+// runtime revert in the guest's `cosmwasm_std::Api::bn254_*` wrapper.
+const BN254_OK: u32 = 0;
+const BN254_PAIRING_INVALID: u32 = 1;
+const BN254_ERR_INVALID_INPUT_LENGTH: u32 = 2;
+const BN254_ERR_NOT_ON_CURVE: u32 = 3;
+const BN254_ERR_NOT_IN_SUBGROUP: u32 = 4;
+const BN254_ERR_INVALID_FIELD_ELEMENT: u32 = 5;
+const BN254_ERR_BACKEND: u32 = 6;
+const BN254_ERR_TOO_MANY_PAIRS: u32 = 7;
+
+/// Maximum number of (G1, G2) pairs accepted by `do_bn254_pairing_equality`
+/// in a single call. Each pair is 192 bytes; 64 pairs = 12 288 bytes of
+/// input, which already costs ~2.2M SDK gas. Larger inputs are rejected
+/// before any decoding to bound worst-case host time.
+const MAX_BN254_PAIRING_PAIRS: usize = 64;
+const MAX_BN254_PAIRING_INPUT: usize = MAX_BN254_PAIRING_PAIRS * 192;
+
+#[inline]
+fn bn254_error_code(err: &Bn254Error) -> u32 {
+    match err {
+        Bn254Error::InvalidInputLength { .. } => BN254_ERR_INVALID_INPUT_LENGTH,
+        Bn254Error::InvalidPairingInputLength(_) => BN254_ERR_INVALID_INPUT_LENGTH,
+        Bn254Error::NotOnCurve => BN254_ERR_NOT_ON_CURVE,
+        Bn254Error::NotInSubgroup => BN254_ERR_NOT_IN_SUBGROUP,
+        Bn254Error::InvalidFieldElement => BN254_ERR_INVALID_FIELD_ELEMENT,
+        Bn254Error::BackendError(_) => BN254_ERR_BACKEND,
+        // `Bn254Error` is marked `#[non_exhaustive]`. Map any future variant
+        // to the generic backend code so we never accidentally pass through
+        // a CryptoError silently.
+        _ => BN254_ERR_BACKEND,
+    }
+}
