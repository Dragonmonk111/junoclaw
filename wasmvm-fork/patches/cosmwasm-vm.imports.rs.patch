+/// BN254 ECADD host function. Input: 128 bytes. Output: 64 bytes.
+pub fn do_bn254_add<A: BackendApi + 'static, S: Storage + 'static, Q: Querier + 'static>(
+    mut env: FunctionEnvMut<Environment<A, S, Q>>,
+    input_ptr: u32,
+) -> VmResult<u32> {
+    let input = read_region(
+        &env.data().memory(&env),
+        input_ptr,
+        2 * G1_BYTES as u32 /* == 128 */ as usize,
+    )?;
+    process_gas_info(&mut env, GasInfo::with_cost(BN254_ADD_COST))?;
+    let result = bn254_add(&input).map_err(bn254_error_to_vm)?;
+    write_to_contract(&mut env, &result)
+}
+
+/// BN254 ECMUL host function. Input: 96 bytes. Output: 64 bytes.
+pub fn do_bn254_scalar_mul<A: BackendApi + 'static, S: Storage + 'static, Q: Querier + 'static>(
+    mut env: FunctionEnvMut<Environment<A, S, Q>>,
+    input_ptr: u32,
+) -> VmResult<u32> {
+    let input = read_region(&env.data().memory(&env), input_ptr, 96)?;
+    process_gas_info(&mut env, GasInfo::with_cost(BN254_SCALAR_MUL_COST))?;
+    let result = bn254_scalar_mul(&input).map_err(bn254_error_to_vm)?;
+    write_to_contract(&mut env, &result)
+}
+
+/// BN254 ECPAIRING equality host function.
+///
+/// Input: `192 · N` bytes (N ≤ `MAX_BN254_PAIRING_PAIRS`).
+/// Output: 1 byte (0 or 1).
+///
+/// Gas: `BN254_PAIRING_BASE_COST + N · BN254_PAIRING_PER_PAIR_COST`. Charged
+/// before the operation so adversarial callers cannot under-pay by supplying
+/// a malformed prefix of a large input.
+pub fn do_bn254_pairing_equality<
+    A: BackendApi + 'static,
+    S: Storage + 'static,
+    Q: Querier + 'static,
+>(
+    mut env: FunctionEnvMut<Environment<A, S, Q>>,
+    input_ptr: u32,
+) -> VmResult<u32> {
+    // Read the region length first so we can charge gas correctly before
+    // materializing the full input.
+    let region_len = read_region_len(&env.data().memory(&env), input_ptr)?;
+    if region_len % 192 != 0 {
+        return Err(VmError::generic_err(format!(
+            "BN254: pairing input length {region_len} is not a multiple of 192"
+        )));
+    }
+    let n_pairs = region_len / 192;
+    if n_pairs > MAX_BN254_PAIRING_PAIRS {
+        return Err(VmError::generic_err(format!(
+            "BN254: too many pairing pairs ({n_pairs} > {MAX_BN254_PAIRING_PAIRS})"
+        )));
+    }
+    process_gas_info(&mut env, GasInfo::with_cost(pairing_cost(n_pairs)))?;
+    let input = read_region(&env.data().memory(&env), input_ptr, region_len)?;
+    let ok = bn254_pairing_equality(&input).map_err(bn254_error_to_vm)?;
+    write_to_contract(&mut env, &[ok as u8])
+}
+
+fn bn254_error_to_vm(err: Bn254Error) -> VmError {
+    // Map to VmError::generic_err with the prefixed string the guest already
+    // sees for other crypto errors. This keeps contract-side pattern matching
+    // consistent across curves.
+    VmError::generic_err(err.to_string())
+}
