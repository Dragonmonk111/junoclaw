+    #[cfg(feature = "cosmwasm_2_3")]
+    fn bn254_add(&self, input: &[u8]) -> Result<Vec<u8>, CryptoError> {
+        if input.len() != 128 {
+            return Err(CryptoError::generic_err("bn254_add: input must be 128 bytes"));
+        }
+        let input_region = build_region(input);
+        let input_region_ptr = &*input_region as *const Region<'_> as u32;
+        let result = unsafe { bn254_add(input_region_ptr) };
+        match result {
+            0 => {
+                let data = unsafe { consume_region(result as *mut Region<'_>) };
+                Ok(data)
+            }
+            _ => {
+                let err_region = unsafe { Region::from_raw(result as *mut u8, 0, 0) };
+                let msg = unsafe { consume_region(result as *mut Region<'_>) };
+                let msg_string = String::from_utf8_lossy(&msg).into_owned();
+                Err(CryptoError::generic_err(msg_string))
+            }
+        }
+    }
+
+    #[cfg(feature = "cosmwasm_2_3")]
+    fn bn254_scalar_mul(&self, input: &[u8]) -> Result<Vec<u8>, CryptoError> {
+        if input.len() != 96 {
+            return Err(CryptoError::generic_err(
+                "bn254_scalar_mul: input must be 96 bytes",
+            ));
+        }
+        let input_region = build_region(input);
+        let input_region_ptr = &*input_region as *const Region<'_> as u32;
+        let result = unsafe { bn254_scalar_mul(input_region_ptr) };
+        match result {
+            0 => {
+                let data = unsafe { consume_region(result as *mut Region<'_>) };
+                Ok(data)
+            }
+            _ => {
+                let msg = unsafe { consume_region(result as *mut Region<'_>) };
+                let msg_string = String::from_utf8_lossy(&msg).into_owned();
+                Err(CryptoError::generic_err(msg_string))
+            }
+        }
+    }
+
+    #[cfg(feature = "cosmwasm_2_3")]
+    fn bn254_pairing_equality(&self, input: &[u8]) -> Result<bool, CryptoError> {
+        if input.len() % 192 != 0 {
+            return Err(CryptoError::generic_err(format!(
+                "bn254_pairing_equality: input length {} is not a multiple of 192",
+                input.len()
+            )));
+        }
+        let input_region = build_region(input);
+        let input_region_ptr = &*input_region as *const Region<'_> as u32;
+        let result = unsafe { bn254_pairing_equality(input_region_ptr) };
+        let data = unsafe { consume_region(result as *mut Region<'_>) };
+        match data.as_slice() {
+            [0u8] => Ok(false),
+            [1u8] => Ok(true),
+            _ => Err(CryptoError::generic_err(
+                "bn254_pairing_equality: host returned invalid discriminant",
+            )),
+        }
+    }
