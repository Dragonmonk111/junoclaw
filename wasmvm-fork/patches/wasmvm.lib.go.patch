+
+// ── BN254 (alt_bn128) host functions ─────────────────────────────────────
+//
+// Added by wasmvm-fork as part of the JunoClaw BN254 precompile proposal.
+// Each wrapper marshals a single []byte across cgo, invokes the Rust
+// implementation in cosmwasm-crypto-bn254, and returns an error on malformed
+// input. Gas is charged by cosmwasm-vm via `do_bn254_*` — the Go surface is
+// a thin passthrough used only by non-vm tooling (key rotation scripts,
+// benchmarks, etc.).
+
+// Bn254Add performs a BN254 G1 point addition. Input must be 128 bytes.
+// Output is 64 bytes.
+func Bn254Add(input []byte) ([]byte, error) {
+	return api.Bn254Add(input)
+}
+
+// Bn254ScalarMul performs a BN254 G1 scalar multiplication.
+// Input must be 96 bytes (point || scalar, big-endian). Output is 64 bytes.
+func Bn254ScalarMul(input []byte) ([]byte, error) {
+	return api.Bn254ScalarMul(input)
+}
+
+// Bn254PairingEquality checks Π e(G1_i, G2_i) = 1 over the supplied pairs.
+// Input length must be a multiple of 192; empty input returns true (matches
+// EIP-197).
+func Bn254PairingEquality(input []byte) (bool, error) {
+	return api.Bn254PairingEquality(input)
+}
