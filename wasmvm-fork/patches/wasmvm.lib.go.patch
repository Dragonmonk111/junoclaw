diff --git a/internal/api/bn254.go b/internal/api/bn254.go
new file mode 100644
--- /dev/null
+++ b/internal/api/bn254.go
@@ -0,0 +1,82 @@
+//go:build cgo && !nolink_libwasmvm
+
+package api
+
+// #include <stdlib.h>
+// #include "bindings.h"
+import "C"
+
+import (
+	"fmt"
+	"runtime"
+)
+
+// Bn254Add performs a G1 point addition.
+func Bn254Add(input []byte) ([]byte, error) {
+	if got := len(input); got != 128 {
+		return nil, fmt.Errorf("Bn254Add: input must be 128 bytes, got %d", got)
+	}
+	view := makeView(input)
+	defer runtime.KeepAlive(input)
+	errMsg := uninitializedUnmanagedVector()
+
+	out := C.bn254_add_ffi(view, &errMsg)
+	if err := errorWithMessage(C.uint8_t(0), errMsg); err != nil {
+		return nil, err
+	}
+	result := copyAndDestroyUnmanagedVector(out)
+	if len(result) != 64 {
+		return nil, fmt.Errorf(
+			"Bn254Add: host returned %d bytes, expected 64", len(result),
+		)
+	}
+	return result, nil
+}
+
+// Bn254ScalarMul performs a G1 scalar multiplication.
+func Bn254ScalarMul(input []byte) ([]byte, error) {
+	if got := len(input); got != 96 {
+		return nil, fmt.Errorf("Bn254ScalarMul: input must be 96 bytes, got %d", got)
+	}
+	view := makeView(input)
+	defer runtime.KeepAlive(input)
+	errMsg := uninitializedUnmanagedVector()
+
+	out := C.bn254_scalar_mul_ffi(view, &errMsg)
+	if err := errorWithMessage(C.uint8_t(0), errMsg); err != nil {
+		return nil, err
+	}
+	result := copyAndDestroyUnmanagedVector(out)
+	if len(result) != 64 {
+		return nil, fmt.Errorf(
+			"Bn254ScalarMul: host returned %d bytes, expected 64", len(result),
+		)
+	}
+	return result, nil
+}
+
+// Bn254PairingEquality checks Π e(G1_i, G2_i) = 1.
+func Bn254PairingEquality(input []byte) (bool, error) {
+	if len(input)%192 != 0 {
+		return false, fmt.Errorf(
+			"Bn254PairingEquality: input length %d is not a multiple of 192",
+			len(input),
+		)
+	}
+	view := makeView(input)
+	defer runtime.KeepAlive(input)
+	errMsg := uninitializedUnmanagedVector()
+
+	flag := C.bn254_pairing_equality_ffi(view, &errMsg)
+	switch flag {
+	case 0:
+		return false, nil
+	case 1:
+		return true, nil
+	case 2:
+		msg := copyAndDestroyUnmanagedVector(errMsg)
+		return false, fmt.Errorf("Bn254PairingEquality: %s", string(msg))
+	default:
+		return false, fmt.Errorf("Bn254PairingEquality: unexpected flag %d", flag)
+	}
+}
