+//! C-ABI shims for the three BN254 host functions, callable from Go via cgo.
+//!
+//! These wrappers exist only so that a patched `junod` build can route
+//! `x/wasm` BN254 calls to the native Rust implementation without changing
+//! any higher-level wasmvm surface. They follow the same
+//! out-parameter-plus-UnmanagedVector pattern used by the existing
+//! `libwasmvm` public API.
+
+use cosmwasm_crypto_bn254::{bn254_add, bn254_pairing_equality, bn254_scalar_mul};
+
+use crate::error::{handle_c_error_default, Error};
+use crate::memory::{ByteSliceView, UnmanagedVector};
+
+#[no_mangle]
+pub extern "C" fn bn254_add_ffi(
+    input: ByteSliceView,
+    error_msg: Option<&mut UnmanagedVector>,
+) -> UnmanagedVector {
+    let r: Result<Vec<u8>, Error> = (|| {
+        let bytes = input
+            .read()
+            .ok_or_else(|| Error::unset_arg("bn254_add: input is nil"))?;
+        let out = bn254_add(bytes)
+            .map_err(|e| Error::generic_err(format!("bn254_add: {e}")))?;
+        Ok(out.to_vec())
+    })();
+    let data = handle_c_error_default(r, error_msg);
+    UnmanagedVector::new(Some(data))
+}
+
+#[no_mangle]
+pub extern "C" fn bn254_scalar_mul_ffi(
+    input: ByteSliceView,
+    error_msg: Option<&mut UnmanagedVector>,
+) -> UnmanagedVector {
+    let r: Result<Vec<u8>, Error> = (|| {
+        let bytes = input
+            .read()
+            .ok_or_else(|| Error::unset_arg("bn254_scalar_mul: input is nil"))?;
+        let out = bn254_scalar_mul(bytes)
+            .map_err(|e| Error::generic_err(format!("bn254_scalar_mul: {e}")))?;
+        Ok(out.to_vec())
+    })();
+    let data = handle_c_error_default(r, error_msg);
+    UnmanagedVector::new(Some(data))
+}
+
+#[no_mangle]
+pub extern "C" fn bn254_pairing_equality_ffi(
+    input: ByteSliceView,
+    error_msg: Option<&mut UnmanagedVector>,
+) -> u8 {
+    let r: Result<bool, Error> = (|| {
+        let bytes = input
+            .read()
+            .ok_or_else(|| Error::unset_arg("bn254_pairing_equality: input is nil"))?;
+        bn254_pairing_equality(bytes)
+            .map_err(|e| Error::generic_err(format!("bn254_pairing_equality: {e}")))
+    })();
+    match r {
+        Ok(true) => 1,
+        Ok(false) => 0,
+        Err(err) => {
+            if let Some(slot) = error_msg {
+                *slot = UnmanagedVector::new(Some(err.to_string().into_bytes()));
+            }
+            2 // sentinel distinct from 0/1
+        }
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use crate::memory::ByteSliceView;
+
+    #[test]
+    fn add_roundtrip_through_ffi() {
+        // G + O -> G
+        let mut input = [0u8; 128];
+        input[31] = 1; // x = 1
+        input[63] = 2; // y = 2
+        let mut err = UnmanagedVector::default();
+        let out = bn254_add_ffi(ByteSliceView::from_option(Some(&input)), Some(&mut err));
+        let bytes = out.consume().expect("non-empty");
+        assert_eq!(&bytes[..64], &input[..64]);
+        assert!(!err.is_some());
+    }
+
+    #[test]
+    fn pairing_empty_is_true_through_ffi() {
+        let mut err = UnmanagedVector::default();
+        let out =
+            bn254_pairing_equality_ffi(ByteSliceView::from_option(Some(&[])), Some(&mut err));
+        assert_eq!(out, 1);
+    }
+}
