+
+#[cfg(feature = "cosmwasm_2_3")]
+fn ml_dsa_error_from_code(code: u32) -> VerificationError {
+    match code {
+        2 => VerificationError::generic_err("ml-dsa: invalid input length"),
+        3 => VerificationError::generic_err("ml-dsa: unknown variant"),
+        4 => VerificationError::generic_err("ml-dsa: invalid public key"),
+        5 => VerificationError::generic_err("ml-dsa: signature verification failed"),
+        c => VerificationError::generic_err(format!("ml-dsa: unknown error code {c}")),
+    }
