+[package]
+name = "cosmwasm-crypto-bn254"
+version = "0.1.0"
+edition = "2021"
+rust-version = "1.70"
+description = "BN254 (alt_bn128) elliptic-curve host-function primitives for the CosmWasm VM. Mirrors EIP-196 / EIP-197 / EIP-1108 semantics and gas."
+license = "Apache-2.0"
+repository = "https://github.com/juno-claw/wasmvm-fork"
+categories = ["cryptography", "no-std", "wasm"]
+keywords = ["bn254", "alt_bn128", "cosmwasm", "groth16", "precompile"]
+
+[lib]
+name = "cosmwasm_crypto_bn254"
+path = "src/lib.rs"
+
+[features]
+default = ["std"]
+# With "std" the error type implements std::error::Error and we allocate
+# scratch buffers on the heap. Without it, the crate is no_std-compatible
+# so that it can be linked into Wasm builds of cosmwasm-vm host modules.
+std = []
+
+[dependencies]
+# Backend: arkworks BN254. Version matches the JunoClaw zk-verifier contract
+# so that precompile and pure-Wasm paths are bit-identical for differential
+# testing.
+ark-bn254     = { version = "0.5", default-features = false, features = ["curve"] }
+ark-ec        = { version = "0.5", default-features = false }
+ark-ff        = { version = "0.5", default-features = false }
+ark-serialize = { version = "0.5", default-features = false }
+ark-std       = { version = "0.5", default-features = false }
+
+[dev-dependencies]
+hex       = "0.4"
+criterion = { version = "0.5", default-features = false, features = ["cargo_bench_support"] }
+
+[[bench]]
+name    = "bn254"
+harness = false
+
+[[test]]
+name = "vectors"
+path = "tests/vectors.rs"
+
diff --git a/packages/crypto-bn254/benches/bn254.rs b/packages/crypto-bn254/benches/bn254.rs
