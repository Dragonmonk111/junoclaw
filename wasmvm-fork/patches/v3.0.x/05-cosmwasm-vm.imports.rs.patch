+/// BN254 G1 point addition (ECADD `0x06`).
+///
+/// Reads 128 bytes from `input_ptr`, writes 64 bytes of result to `out_ptr`.
+/// Returns 0 on success, non-zero error code on failure. Gas is charged
+/// before the operation.
+pub fn do_bn254_add<A: BackendApi + 'static, S: Storage + 'static, Q: Querier + 'static>(
+    mut env: FunctionEnvMut<Environment<A, S, Q>>,
+    input_ptr: u32,
+    out_ptr: u32,
+) -> VmResult<u32> {
+    let (data, mut store) = env.data_and_store_mut();
+
+    let input = read_region(data, &mut store, input_ptr, 2 * G1_BYTES)?;
+    let gas_info = GasInfo::with_cost(BN254_ADD_COST);
+    process_gas_info(data, &mut store, gas_info)?;
+
+    let result = match bn254_add(&input) {
+        Ok(bytes) => bytes,
+        Err(e) => return Ok(bn254_error_code(&e)),
+    };
+    write_region(data, &mut store, out_ptr, &result)?;
+    Ok(BN254_OK)
+}
+
+/// BN254 G1 scalar multiplication (ECMUL `0x07`).
+///
+/// Reads 96 bytes from `input_ptr` (`g1_point || scalar_be`), writes 64 bytes
+/// of result to `out_ptr`. Returns 0 on success, non-zero error code on
+/// failure. Scalars are reduced mod `r` per EIP-196.
+pub fn do_bn254_scalar_mul<A: BackendApi + 'static, S: Storage + 'static, Q: Querier + 'static>(
+    mut env: FunctionEnvMut<Environment<A, S, Q>>,
+    input_ptr: u32,
+    out_ptr: u32,
+) -> VmResult<u32> {
+    let (data, mut store) = env.data_and_store_mut();
+
+    let input = read_region(data, &mut store, input_ptr, G1_BYTES + FR_BYTES)?;
+    let gas_info = GasInfo::with_cost(BN254_SCALAR_MUL_COST);
+    process_gas_info(data, &mut store, gas_info)?;
+
+    let result = match bn254_scalar_mul(&input) {
+        Ok(bytes) => bytes,
+        Err(e) => return Ok(bn254_error_code(&e)),
+    };
+    write_region(data, &mut store, out_ptr, &result)?;
+    Ok(BN254_OK)
+}
+
+/// BN254 pairing equality check (ECPAIRING `0x08`).
+///
+/// Reads `192·N` bytes from `input_ptr`. Returns 0 if the pairing product
+/// equals 1 in `Gt`, 1 if it doesn't, and non-zero error codes otherwise.
+/// Gas is charged on the supplied length before any decoding so that
+/// adversarial callers cannot under-pay by malforming the input.
+pub fn do_bn254_pairing_equality<
+    A: BackendApi + 'static,
+    S: Storage + 'static,
+    Q: Querier + 'static,
+>(
+    mut env: FunctionEnvMut<Environment<A, S, Q>>,
+    input_ptr: u32,
+) -> VmResult<u32> {
+    let (data, mut store) = env.data_and_store_mut();
+
+    let input = read_region(data, &mut store, input_ptr, MAX_BN254_PAIRING_INPUT)?;
+    if input.len() % 192 != 0 {
+        return Ok(BN254_ERR_INVALID_INPUT_LENGTH);
+    }
+    let n_pairs = input.len() / 192;
+    if n_pairs > MAX_BN254_PAIRING_PAIRS {
+        return Ok(BN254_ERR_TOO_MANY_PAIRS);
+    }
+
+    let gas_info = GasInfo::with_cost(pairing_cost(n_pairs));
+    process_gas_info(data, &mut store, gas_info)?;
+
+    match bn254_pairing_equality(&input) {
+        Ok(true) => Ok(BN254_OK),
+        Ok(false) => Ok(BN254_PAIRING_INVALID),
+        Err(e) => Ok(bn254_error_code(&e)),
+    }
+}
