# JunoClaw WAVS Operator Configuration
# Copy to .env and fill in your values

# ── Bridge Daemon Config ──

# Juno testnet RPC
JUNO_RPC="https://juno-testnet-rpc.polkachu.com"
CHAIN_ID="uni-7"
GAS_PRICE="0.025ujunox"
DENOM="ujunox"

# Agent-company contract address on uni-7
AGENT_COMPANY_CONTRACT=""

# Operator wallet mnemonic — must be admin, governance, or task_ledger
# of the agent-company contract to submit attestations/randomness
WAVS_OPERATOR_MNEMONIC=""

# WAVS aggregator endpoint (for bridge daemon polling)
WAVS_AGGREGATOR_URL="http://localhost:8080"
POLL_INTERVAL_MS="5000"

# ── WAVS Component Config ──

# Cosmos mnemonic for the WAVS CLI operator (service registration)
WAVS_CLI_COSMOS_MNEMONIC=""

# Optional: API keys for data source access (prefix with WAVS_ENV_)
# WAVS_ENV_WEATHER_API_KEY="your_api_key"
# WAVS_ENV_DATA_API_KEY="your_api_key"
