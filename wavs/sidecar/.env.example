# JunoClaw WAVS Validator Sidecar — Environment Configuration
#
# Copy this file to .env and fill in your values.
# DO NOT commit the .env file — it contains your operator wallet mnemonic.
#
# Quick start:
#   cp .env.example .env
#   nano .env                          # fill in WAVS_CLI_COSMOS_MNEMONIC
#   docker compose up -d               # start the sidecar
#   docker compose logs -f wavs-sidecar  # watch logs

# ─────────────────────────────────────────────
# Chain Configuration
# ─────────────────────────────────────────────

# Your validator's local Juno RPC endpoint.
#
# Option A (host networking — default in docker-compose.yml):
#   Use localhost. The container shares the host network stack.
WAVS_CHAIN_RPC=http://localhost:26657
#
# Option B (bridge networking — if you commented out network_mode: host):
#   Use the Docker gateway hostname instead:
# WAVS_CHAIN_RPC=http://host.docker.internal:26657

# Juno chain ID
#   uni-7  = testnet (use this first to verify your setup)
#   juno-1 = mainnet (switch after testnet validation)
WAVS_CHAIN_ID=uni-7

# The agent-company contract address to watch for events
# Testnet (uni-7):
WAVS_CONTRACT=juno1k8dxll425mcclacaxhrmkx9w5pznx9w5ggmw53tpj0c009ngfnjstj85k6
# Mainnet (juno-1) — uncomment when mainnet contracts are deployed:
# WAVS_CONTRACT=<mainnet agent-company address>

# ─────────────────────────────────────────────
# WAVS Configuration
# ─────────────────────────────────────────────

# WAVS service ID (from service registration)
WAVS_SERVICE_ID=572b188a0605b36f9019833720de30125a4dfa4c3c614d90801068e2335a2a81

# Component registry
#   wa.dev = production WASI component registry
#   For self-hosted: use your warg-registry address (e.g. warg-registry:8090)
WAVS_COMPONENT_REGISTRY=wa.dev

# Log level: error, warn, info, debug, trace
# Use "debug" when first setting up to verify TEE detection and event watching.
# Switch to "info" once everything is confirmed working.
RUST_LOG=info

# ─────────────────────────────────────────────
# Operator Wallet
# ─────────────────────────────────────────────

# Mnemonic for the wallet that submits attestation TXs.
#
# IMPORTANT:
#   - Use your validator's OPERATOR wallet — NOT your consensus key
#   - NOT your personal staking wallet — use a dedicated hot wallet
#   - The wallet needs a small JUNO balance for gas fees
#   - Gas cost: ~0.075 ujuno per unit, ~200k gas per attestation TX
#   - Roughly: 1 JUNO covers ~60+ attestation TXs
#   - Top up when balance drops below 0.5 JUNO
#
# SECURITY:
#   - This mnemonic is loaded into the TEE enclave at startup
#   - With SGX: enclave memory is encrypted — even root cannot read it
#   - With SEV: VM memory is encrypted by the AMD Secure Processor
#   - Without TEE: mnemonic is in container memory (standard Docker isolation only)
#   - NEVER use the same mnemonic as your validator consensus key
WAVS_CLI_COSMOS_MNEMONIC=<your operator wallet mnemonic here>

# ─────────────────────────────────────────────
# TEE Hardware Detection
# ─────────────────────────────────────────────
# The WAVS runtime detects the TEE type automatically from the mounted device.
# No config needed — just ensure the correct device is mounted in docker-compose.yml.
#
# ┌─────────────────────────────────────────────────────────────────────┐
# │ How to verify your TEE hardware (run on the HOST, not in Docker):  │
# ├─────────────────────────────────────────────────────────────────────┤
# │                                                                     │
# │ Intel SGX:                                                          │
# │   ls -la /dev/sgx_enclave /dev/sgx_provision                       │
# │   # Both files must exist. If missing, check BIOS settings:        │
# │   # BIOS → Security → SGX → Enabled (not "Software Controlled")   │
# │   # After BIOS change: reboot, then check again                    │
# │                                                                     │
# │ AMD SEV:                                                            │
# │   ls -la /dev/sev                                                   │
# │   # Must exist. If missing:                                         │
# │   # BIOS → Advanced → CPU Config → SEV → Enabled                  │
# │   # Also check: dmesg | grep -i sev                                │
# │   # Should show: "SEV supported" or "SEV-ES supported"             │
# │                                                                     │
# │ AMD SEV-SNP (strongest):                                            │
# │   dmesg | grep SEV-SNP                                              │
# │   # Should show: "SEV-SNP supported"                               │
# │   # Requires AMD EPYC Genoa (9004 series) or newer                 │
# │   # Same /dev/sev device — SNP is auto-detected                    │
# │                                                                     │
# │ CPU model check:                                                    │
# │   lscpu | grep "Model name"                                        │
# │   # Intel Xeon (Ice Lake 3rd gen+)  → SGX capable                  │
# │   # AMD EPYC 7003 (Milan)           → SEV capable                  │
# │   # AMD EPYC 9004 (Genoa)           → SEV-SNP capable              │
# │                                                                     │
# │ No TEE detected?                                                    │
# │   The sidecar will still run but in software mode only.             │
# │   Software mode = correct computation, no hardware attestation.     │
# │   This is the same as the Akash operator — no point running both.  │
# │   If you don't have TEE hardware, use the Akash operator instead.  │
# └─────────────────────────────────────────────────────────────────────┘
#
# Attestation trust levels:
#   SGX attestation     → Intel CPU signs the result (high trust)
#   SEV attestation     → AMD Secure Processor signs the result (high trust)
#   SEV-SNP attestation → AMD SP + memory integrity (highest trust)
#   Software mode       → No hardware signature (same as Akash operator)
